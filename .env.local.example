# Локальные переменные окружения для разработки
# Скопируйте этот файл в .env.local и заполните значения

# Ozon API credentials
OZON_API_KEY=
OZON_CLIENT_ID=

# Groq AI (ai-sdk) — AI-помощник по индивидуальным заказам
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=
# Необязательно: модель Groq (по умолчанию llama-3.3-70b-versatile)
GROQ_MODEL=

# Telegram Bot API — отправка заявок на индивидуальный заказ
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (необязательный канал доставки заявок на email)
RESEND_API_KEY=
ORDER_EMAIL_TO=
ORDER_EMAIL_FROM=

# Node environment (автоматически устанавливается Next.js)
# NODE_ENV=development
