# Ozon API credentials
OZON_API_KEY=your_api_key_here
OZON_CLIENT_ID=your_client_id_here

# Groq AI (ai-sdk) — основной провайдер AI-помощника
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=
# Необязательно: модель Groq (по умолчанию llama3-groq-70b-8192-tool-use-preview)
# Рекомендуется модель с поддержкой tool calling:
# llama3-groq-70b-8192-tool-use-preview (стабильный tool calling)
# llama-3.3-70b-versatile (более мощная, но нестабильный tool calling)
GROQ_MODEL=llama3-groq-70b-8192-tool-use-preview

# Cerebras AI — резервный провайдер (fallback если Groq недоступен)
# Ключ: https://cloud.cerebras.ai
# Модели с поддержкой tool calling: gpt-oss-120b, zai-glm-4.7
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# OpenRouter — последний запасной провайдер (fallback если Groq и Cerebras недоступны)
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Langfuse — трассировка и логирование запросов к AI (опционально)
# Ключи: https://cloud.langfuse.com → Settings → API Keys
# EU: https://cloud.langfuse.com | US: https://us.cloud.langfuse.com
LANGFUSE_SECRET_KEY="sk-lf-ecc6d5fe-212d-4db4-a5f1-9f6d6f675335"
LANGFUSE_PUBLIC_KEY="pk-lf-b09541dc-3ade-482c-a50c-6e21d445e1a5"
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Telegram Bot API — отправка заявок на индивидуальный заказ
# Токен бота получите у @BotFather, chat id — у @userinfobot или @getmyid_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (необязательный канал доставки заявок на email) — https://resend.com
RESEND_API_KEY=
ORDER_EMAIL_TO=
ORDER_EMAIL_FROM=

# ─────────────────────────────────────────────────────────────
# Личный кабинет: БД, авторизация, оплата, видео
# ─────────────────────────────────────────────────────────────

# PostgreSQL — строка подключения для Drizzle ORM и better-auth
# Формат: postgres://user:password@host:5432/database
DATABASE_URL=

# better-auth — авторизация клиентов
# Секрет сгенерируйте командой: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Базовый URL приложения (в проде — https://stariva.ru)
BETTER_AUTH_URL=http://localhost:3000
# Публичный URL сайта (для редиректов после оплаты)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# YooKassa — приём онлайн-платежей за мастер-классы (https://yookassa.ru)
# shopId и секретный ключ из личного кабинета ЮKassa (для теста — тестовый магазин)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Yandex Cloud S3 — хранилище видеоуроков и материалов
# Статические ключи доступа сервисного аккаунта с ролью storage.viewer/editor
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1
YANDEX_S3_ACCESS_KEY_ID=
YANDEX_S3_SECRET_ACCESS_KEY=
YANDEX_S3_BUCKET=

# Node environment
NODE_ENV=development
